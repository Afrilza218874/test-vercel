{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/tampil.php", "dest": "/api/tampil.php" },
    { "src": "/api_mahasiswa.php", "dest": "/api/api_mahasiswa.php" },
    { "src": "/(.*\\.php)", "dest": "/api/$1" }
  ]
}
